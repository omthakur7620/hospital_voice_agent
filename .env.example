# ===== LOCAL DEVELOPMENT =====
# Use these settings when running locally without Docker

# Database - Local PostgreSQL
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hospital_voice
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=hospital_voice

# ===== DOCKER DEPLOYMENT =====
# Use these settings when running with Docker Compose
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/hospital_voice
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hospital_voice

# App Configuration
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://vapi.ai

# Timezone Configuration
TIMEZONE=Asia/Kolkata

# Business Rules
SLOT_DURATION_MINUTES=30
MAX_ALTERNATIVE_SLOTS=3
BOOKING_WINDOW_DAYS=30

# Data Files
HOSPITAL_DATA_PATH=data/hospital_data.json

# ===== PRODUCTION OVERRIDES =====
# For production deployments:
# APP_ENV=production
# DEBUG=false
# LOG_LEVEL=WARNING
# ALLOWED_ORIGINS=https://yourdomain.com
# DATABASE_URL=postgresql+asyncpg://produser:prodpassword@prod-db-host:5432/hospital_voice
