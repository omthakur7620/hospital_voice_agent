# .env.render - Environment variables for Render.com deployment
# These should be set in Render dashboard, not committed

# ===== RENDER ENVIRONMENT =====
# DATABASE_URL - Automatically injected by Render PostgreSQL service
# Do NOT set manually - Render provides: postgresql://user:pass@host/hospital_voice

# App Configuration - Production
APP_ENV=production
DEBUG=false
LOG_LEVEL=WARNING

# Port - Render provides PORT env var (usually 8080)
# but we can override in dashboard if needed
# PORT=8080

# API Configuration
ALLOWED_ORIGINS=https://vapi.ai,https://yourdomain.com

# Timezone Configuration
TIMEZONE=Asia/Kolkata

# Business Rules
SLOT_DURATION_MINUTES=30
MAX_ALTERNATIVE_SLOTS=3
BOOKING_WINDOW_DAYS=30

# Data Files
HOSPITAL_DATA_PATH=data/hospital_data.json

# ===== SETUP INSTRUCTIONS =====
# 1. In Render dashboard, create new Web Service
# 2. Connect your GitHub repository
# 3. In Environment section, add these variables:
#    - APP_ENV = production
#    - DEBUG = false
#    - LOG_LEVEL = WARNING
#    - ALLOWED_ORIGINS = https://yourdomain.com
#    - (Others above)
# 4. Create PostgreSQL database
# 5. Render auto-injects DATABASE_URL
# 6. Deploy!
#
# Note: Replace "yourdomain.com" with your actual domain
