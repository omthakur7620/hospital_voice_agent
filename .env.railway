# .env.railway - Production settings for Railway deployment
# These are template values - Railway will override most with environment variables

# ===== RAILWAY ENVIRONMENT =====
# Database: Automatically injected by Railway PostgreSQL plugin
# DO NOT SET DATABASE_URL HERE - Railway provides it automatically
# DATABASE_URL will be set to: postgresql+asyncpg://user:pass@host:5432/railway

# App Configuration - Production
APP_ENV=production
DEBUG=false
LOG_LEVEL=WARNING

# API Configuration
ALLOWED_ORIGINS=https://yourdomain.com,https://vapi.ai

# Timezone Configuration
TIMEZONE=Asia/Kolkata

# Business Rules
SLOT_DURATION_MINUTES=30
MAX_ALTERNATIVE_SLOTS=3
BOOKING_WINDOW_DAYS=30

# Data Files
HOSPITAL_DATA_PATH=data/hospital_data.json

# ===== INSTRUCTIONS =====
# 1. Create this file in Railway environment variables dashboard
# 2. Set each variable as specified above
# 3. DATABASE_URL is automatically provided by Railway (no need to set)
# 4. Replace "yourdomain.com" with your actual domain
# 5. Update ALLOWED_ORIGINS for CORS (comma-separated)
# 6. Redeploy application for changes to take effect
